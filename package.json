{
  "name": "liber",
  "private": true,
  "packageManager": "npm@10.9.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "overrides": {
    "@hono/node-server": "1.19.13",
    "hono": "4.12.25",
    "postcss": "8.5.19",
    "vite": "8.0.16"
  },
  "scripts": {
    "dev": "npm run dev -w @liber/web",
    "build": "npm run build -w @liber/web",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test:database-target && npm run test:baseline && npm run test:readiness && npm run test:demo-buyers && npm run test:secret-scan && npm run test:messaging-migration && npm run test:loi-migration && npm run test --workspaces --if-present",
    "test:baseline": "node scripts/generate-current-baseline.mjs --check",
    "test:database-target": "node --test scripts/database-target.test.mjs",
    "test:readiness": "node --test scripts/readiness-check.test.mjs",
    "test:demo-buyers": "node --test scripts/manage-demo-buyers.test.mjs",
    "test:messaging-migration": "node scripts/test-messaging-migration.mjs static",
    "test:loi-migration": "node scripts/test-loi-migration.mjs",
    "test:secret-scan": "node --test scripts/secret-scan.test.mjs",
    "demo:buyers": "node --env-file-if-exists=.env scripts/with-local-ca.mjs node scripts/manage-demo-buyers.mjs",
    "smoke:routes": "node scripts/route-smoke.mjs",
    "smoke:security": "node scripts/security-smoke.mjs",
    "smoke:no-auth-bypass": "node scripts/forbidden-auth-bypass-smoke.mjs",
    "smoke:secrets": "node scripts/secret-scan.mjs",
    "smoke:visual": "node scripts/visual-smoke.mjs",
    "readiness:env": "node scripts/readiness-check.mjs",
    "readiness:production": "node scripts/readiness-check.mjs --production",
    "db:generate": "prisma generate --schema packages/db/prisma/schema.prisma",
    "db:validate": "prisma validate --schema packages/db/prisma/schema.prisma",
    "db:baseline:generate": "node scripts/generate-current-baseline.mjs",
    "db:baseline:check": "node scripts/generate-current-baseline.mjs --check",
    "db:test-baseline-equivalence": "node scripts/compare-supported-baseline.mjs",
    "db:import-service-areas": "node scripts/import-service-areas.mjs",
    "db:release-la-geography": "node scripts/manage-la-geography-release.mjs",
    "db:rehearse-la-geography": "node scripts/rehearse-la-geography-release.mjs",
    "db:test-geography:fresh": "node scripts/test-geography-migration-fresh.mjs",
    "db:test-geography:upgrade": "node scripts/test-geography-migration-upgrade.mjs",
    "db:test-identity": "node scripts/test-identity-migration.mjs",
    "db:test-messaging:fresh": "node scripts/test-messaging-migration.mjs fresh",
    "db:test-messaging:upgrade": "node scripts/test-messaging-migration.mjs upgrade",
    "db:test-loi:fresh": "node scripts/test-loi-database.mjs fresh",
    "db:test-loi:upgrade": "node scripts/test-loi-database.mjs upgrade",
    "db:test-loi:behavior": "node scripts/test-loi-behavior.mjs",
    "db:test-buyer-profile-atomicity": "node scripts/test-buyer-profile-atomicity.mjs",
    "db:test-seller-property-integrity": "node scripts/test-seller-property-integrity.mjs",
    "db:test-auth-security:staging": "node scripts/test-auth-security-staging.mjs"
  },
  "devDependencies": {
    "prisma": "7.8.0",
    "typescript": "6.0.3",
    "vitest": "4.1.6"
  }
}
