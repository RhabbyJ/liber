generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  BUYER
  SELLER
  ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
}

enum SellerAccessStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum BuyerVisibilityStatus {
  DRAFT
  ACTIVE
  HIDDEN
  SUSPENDED
}

// V1 uses one broad property category with allowlisted property subtypes.
enum PropertyCategory {
  HOME
}

enum PropertySubtype {
  HOME
  CONDO
  TOWNHOUSE
  MANUFACTURED
  LAND
}

enum BadgeType {
  PRE_APPROVED
  EARNEST_MONEY_DEPOSITED
  CASH_BUYER
  NON_CONTINGENT
  VERIFIED_IDENTITY
  VERIFIED_FUNDS
  COMPLETED_TRANSACTION
}

enum BadgeStatus {
  PENDING
  ACTIVE
  EXPIRED
  REJECTED
  REVOKED
}

enum PropertyVerificationStatus {
  NOT_SUBMITTED
  PENDING
  APPROVED
  REJECTED
}

enum PropertyStatus {
  DRAFT
  READY_FOR_REVIEW
  READY_FOR_INVITES
  ARCHIVED
}

enum DocumentType {
  OWNERSHIP
  PRE_APPROVAL
  VERIFIED_FUNDS
  IDENTITY
  OTHER
}

enum DocumentStatus {
  PENDING
  APPROVED
  REJECTED
}

enum OwnershipEvidenceKind {
  GOVERNMENT_ID
  PROPERTY_ADDRESS_PROOF
}

enum InviteStatus {
  SENT
  VIEWED
  ACCEPTED
  DECLINED
  EXPIRED
  WITHDRAWN
}

enum ConversationStatus {
  AWAITING_BUYER
  ACTIVE
  READ_ONLY
  BLOCKED
}

enum ConversationClosedReason {
  INVITE_DECLINED
  INVITE_EXPIRED
  INVITE_WITHDRAWN
  PROPERTY_IDENTITY_CHANGED
  PROPERTY_INELIGIBLE
  SELLER_INELIGIBLE
  BUYER_INELIGIBLE
  USER_SUSPENDED
  USER_BLOCKED
}

enum ConversationParticipantRole {
  SELLER
  BUYER
}

enum MessageKind {
  INVITE
  GUIDED
  FREE_TEXT
  SYSTEM
}

enum MessageModerationStatus {
  ALLOWED
  FLAGGED
  REDACTED
}

enum MessageReportCategory {
  HARASSMENT_OR_THREAT
  DISCRIMINATORY_CONTENT
  FRAUD_OR_SCAM
  SPAM
  SENSITIVE_INFORMATION_REQUEST
  OFF_PLATFORM_PAYMENT_REQUEST
  OTHER
}

enum MessageReportStatus {
  OPEN
  IN_REVIEW
  ACTIONED
  DISMISSED
}

enum EmailOutboxStatus {
  PENDING
  SENDING
  SENT
  FAILED
  CANCELLED
}

enum UploadSessionStatus {
  PENDING
  UPLOADED
  FINALIZED
  REJECTED
  EXPIRED
  CLEANED
}

enum UploadPurpose {
  BUYER_VERIFICATION
  PROPERTY_IMAGE
  PROPERTY_OWNERSHIP
}

enum AuthOperationStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum BuyerDesiredServiceAreaSource {
  SELECTED
  DERIVED
  MIGRATED
}

enum ServiceAreaRelationType {
  CONTAINS
  OVERLAPS
  DISPLAY_PARENT
  SEARCH_ROLLUP
}

model User {
  id            String     @id @db.Uuid
  email         String     @unique
  name          String?
  avatarVariant String?
  roles         UserRole[] @default([])
  status        UserStatus @default(ACTIVE)
  suspendedAt   DateTime?

  buyerProfile             BuyerProfile?
  sellerProperties         SellerProperty[]               @relation("SellerProperties")
  sellerInvites            Invite[]                       @relation("SellerInvites")
  sellerAccess             SellerAccess?                  @relation("SellerAccessUser")
  sellerAccessReviews      SellerAccess[]                 @relation("SellerAccessReviewer")
  notifications            Notification[]
  documents                VerificationDocument[]         @relation("UserDocuments")
  documentsUploaded        VerificationDocument[]         @relation("DocumentUploader")
  badgesGranted            BuyerBadge[]                   @relation("BadgeGranter")
  documentsReviewed        VerificationDocument[]         @relation("DocumentReviewer")
  auditLogs                AdminAuditLog[]                @relation("AuditActor")
  authorityAttestations    SellerProperty[]               @relation("PropertyAuthorityAttester")
  propertyDecisions        PropertyVerificationDecision[] @relation("PropertyDecisionReviewer")
  uploadSessions           UploadSession[]
  authOperations           AuthOperation[]
  conversationParticipants ConversationParticipant[]
  userBlocksCreated        UserBlock[]                    @relation("UserBlockBlocker")
  userBlocksReceived       UserBlock[]                    @relation("UserBlockBlocked")
  messageReportsFiled      MessageReport[]                @relation("MessageReportReporter")
  messageReportsReceived   MessageReport[]                @relation("MessageReportReportedUser")
  messageReportsReviewed   MessageReport[]                @relation("MessageReportReviewer")
  messageOutboxJobs        EmailOutbox[]                  @relation("MessageOutboxRecipient")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SellerAccess {
  id               String             @id @default(cuid())
  userId           String             @unique @db.Uuid
  user             User               @relation("SellerAccessUser", fields: [userId], references: [id], onDelete: Cascade, onUpdate: Restrict)
  status           SellerAccessStatus @default(PENDING)
  reviewedByUserId String?            @db.Uuid
  reviewedBy       User?              @relation("SellerAccessReviewer", fields: [reviewedByUserId], references: [id], onDelete: SetNull, onUpdate: Restrict)
  reviewedAt       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([reviewedByUserId])
}

model BuyerProfile {
  id     String @id @default(cuid())
  userId String @unique @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Restrict)

  displayName         String
  buyerType           String?
  bio                 String?
  buyingPurpose       String?
  desiredLocationText String?
  desiredCity         String?
  desiredNeighborhood String?
  desiredPostalCode   String?
  desiredState        String?
  desiredLat          Decimal?              @db.Decimal(10, 7)
  desiredLng          Decimal?              @db.Decimal(10, 7)
  budgetMin           Decimal?              @db.Decimal(12, 2)
  budgetMax           Decimal?              @db.Decimal(12, 2)
  downPaymentMin      Decimal?              @db.Decimal(12, 2)
  downPaymentMax      Decimal?              @db.Decimal(12, 2)
  visibilityStatus    BuyerVisibilityStatus @default(DRAFT)
  profileCompleteness Int                   @default(0)
  lastRefreshedAt     DateTime?

  criteria            BuyerCriteria[]
  badges              BuyerBadge[]
  invites             Invite[]
  documents           VerificationDocument[]
  desiredServiceAreas BuyerDesiredServiceArea[]
  geographyQuarantine ServiceAreaMigrationQuarantine?
  uploadSessions      UploadSession[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([visibilityStatus])
  @@index([budgetMin, budgetMax])
}

model Market {
  id                       String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug                     String   @unique
  label                    String
  state                    String
  country                  String
  jurisdictionType         String?  @map("jurisdiction_type")
  jurisdictionGeoid        String?  @map("jurisdiction_geoid")
  stableExternalId         String?  @unique(map: "markets_stable_external_id_key") @map("stable_external_id")
  currentBoundaryId        String?  @unique(map: "markets_current_boundary_id_key") @map("current_boundary_id") @db.Uuid
  currentDisplayGeometryId String?  @unique(map: "markets_current_display_geometry_id_key") @map("current_display_geometry_id") @db.Uuid
  centerLat                Float    @map("center_lat")
  centerLng                Float    @map("center_lng")
  bboxWest                 Float    @map("bbox_west")
  bboxSouth                Float    @map("bbox_south")
  bboxEast                 Float    @map("bbox_east")
  bboxNorth                Float    @map("bbox_north")
  active                   Boolean  @default(false)
  createdAt                DateTime @default(now()) @map("created_at")
  updatedAt                DateTime @default(now()) @updatedAt @map("updated_at")

  activationSnapshots     GeographyActivationSnapshot[]
  boundaryVersions        MarketBoundaryVersion[]        @relation("MarketBoundaryVersions")
  currentBoundary         MarketBoundaryVersion?         @relation("CurrentMarketBoundary", fields: [currentBoundaryId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  currentDisplayGeometry  MarketDisplayGeometryVersion?  @relation("CurrentMarketDisplayGeometry", fields: [currentDisplayGeometryId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  datasetVersions         GeographyDatasetVersion[]
  displayGeometryVersions MarketDisplayGeometryVersion[] @relation("MarketDisplayGeometryVersions")
  searchTerms             ServiceAreaSearchTerm[]
  serviceAreas            ServiceArea[]

  @@unique([country, jurisdictionType, jurisdictionGeoid], map: "markets_country_jurisdiction_type_jurisdiction_geoid_key")
  @@map("markets")
}

model ServiceArea {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  marketId           String    @map("market_id") @db.Uuid
  market             Market    @relation(fields: [marketId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  slug               String
  label              String
  type               String
  postalCode         String?   @map("postal_code")
  city               String?
  county             String?
  state              String
  centerLat          Float     @map("center_lat")
  centerLng          Float     @map("center_lng")
  bboxWest           Float     @map("bbox_west")
  bboxSouth          Float     @map("bbox_south")
  bboxEast           Float     @map("bbox_east")
  bboxNorth          Float     @map("bbox_north")
  geojsonPath        String    @map("geojson_path")
  source             String
  sourceVersion      String    @map("source_version")
  sourceLicense      String?   @map("source_license")
  sourceUrl          String?   @map("source_url")
  sourceRetrievalUrl String?   @map("source_retrieval_url")
  geojsonSha256      String?   @map("geojson_sha256")
  stableExternalId   String?   @map("stable_external_id")
  sourceRetrievedAt  DateTime? @map("source_retrieved_at") @db.Date
  currentGeometryId  String?   @unique(map: "service_areas_current_geometry_id_key") @map("current_geometry_id") @db.Uuid
  searchTerms        String[]  @default([]) @map("search_terms")
  active             Boolean   @default(false)
  isPilot            Boolean   @default(false) @map("is_pilot")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @default(now()) @updatedAt @map("updated_at")

  buyerDesiredAreas   BuyerDesiredServiceArea[]
  childRelationships  ServiceAreaRelationship[]    @relation("ServiceAreaRelationshipChild")
  currentGeometry     ServiceAreaGeometryVersion?  @relation("CurrentServiceAreaGeometry", fields: [currentGeometryId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  geometryVersions    ServiceAreaGeometryVersion[] @relation("ServiceAreaGeometryVersions")
  parentRelationships ServiceAreaRelationship[]    @relation("ServiceAreaRelationshipParent")
  reviewedSearchTerms ServiceAreaSearchTerm[]

  @@unique([marketId, slug])
  @@unique([marketId, postalCode])
  @@unique([marketId, stableExternalId], map: "service_areas_market_id_stable_external_id_key")
  @@unique([id, marketId], map: "service_areas_id_market_id_key")
  @@index([marketId, active, type])
  @@index([active, type])
  @@index([postalCode])
  @@map("service_areas")
}

model MarketBoundaryVersion {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  marketId           String   @map("market_id") @db.Uuid
  datasetVersion     String   @map("dataset_version")
  geojson            Json
  sha256             String
  source             String
  sourceVersion      String   @map("source_version")
  sourceLicense      String   @map("source_license")
  sourceUrl          String   @map("source_url")
  sourceRetrievalUrl String   @map("source_retrieval_url")
  sourceRetrievedAt  DateTime @map("source_retrieved_at") @db.Date
  createdAt          DateTime @default(now()) @map("created_at")

  currentFor     Market?                   @relation("CurrentMarketBoundary")
  datasetRecords GeographyDatasetVersion[]
  market         Market                    @relation("MarketBoundaryVersions", fields: [marketId], references: [id], onDelete: Restrict, onUpdate: Restrict)

  @@unique([marketId, datasetVersion])
  @@index([marketId, sha256], map: "market_boundary_versions_market_sha_idx")
  @@map("market_boundary_versions")
}

model MarketDisplayGeometryVersion {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  marketId       String   @map("market_id") @db.Uuid
  datasetVersion String   @map("dataset_version")
  geojson        Json
  sha256         String
  sourceManifest Json     @map("source_manifest")
  createdAt      DateTime @default(now()) @map("created_at")

  currentFor     Market?                   @relation("CurrentMarketDisplayGeometry")
  datasetRecords GeographyDatasetVersion[]
  market         Market                    @relation("MarketDisplayGeometryVersions", fields: [marketId], references: [id], onDelete: Restrict, onUpdate: Restrict)

  @@unique([marketId, datasetVersion])
  @@index([marketId, sha256], map: "market_display_geometry_versions_market_sha_idx")
  @@map("market_display_geometry_versions")
}

model ServiceAreaGeometryVersion {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  serviceAreaId      String   @map("service_area_id") @db.Uuid
  datasetVersion     String   @map("dataset_version")
  geojson            Json
  sha256             String
  sourceSha256       String   @map("source_sha256")
  source             String
  sourceVersion      String   @map("source_version")
  sourceLicense      String   @map("source_license")
  sourceUrl          String   @map("source_url")
  sourceRetrievalUrl String   @map("source_retrieval_url")
  sourceRetrievedAt  DateTime @map("source_retrieved_at") @db.Date
  createdAt          DateTime @default(now()) @map("created_at")

  currentFor  ServiceArea? @relation("CurrentServiceAreaGeometry")
  serviceArea ServiceArea  @relation("ServiceAreaGeometryVersions", fields: [serviceAreaId], references: [id], onDelete: Restrict, onUpdate: Restrict)

  @@unique([serviceAreaId, datasetVersion])
  @@index([serviceAreaId, sha256], map: "service_area_geometry_versions_area_sha_idx")
  @@index([serviceAreaId, createdAt(sort: Desc)], map: "service_area_geometry_versions_area_created_idx")
  @@map("service_area_geometry_versions")
}

model ServiceAreaSearchTerm {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  marketId       String   @map("market_id") @db.Uuid
  serviceAreaId  String   @map("service_area_id") @db.Uuid
  termNormalized String   @map("term_normalized")
  termKind       String   @map("term_kind")
  source         String
  reviewedAt     DateTime @map("reviewed_at")
  createdAt      DateTime @default(now()) @map("created_at")

  market      Market      @relation(fields: [marketId], references: [id], onDelete: Cascade, onUpdate: Restrict)
  serviceArea ServiceArea @relation(fields: [serviceAreaId, marketId], references: [id, marketId], onDelete: Cascade, onUpdate: Restrict)

  @@unique([marketId, termNormalized, serviceAreaId], map: "service_area_search_terms_market_term_prefix_idx")
  @@index([serviceAreaId, marketId], map: "service_area_search_terms_area_idx")
  @@map("service_area_search_terms")
}

model GeographyDatasetVersion {
  id                             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  datasetVersion                 String   @unique @map("dataset_version")
  marketId                       String   @map("market_id") @db.Uuid
  marketBoundaryVersionId        String   @map("market_boundary_version_id") @db.Uuid
  marketDisplayGeometryVersionId String?  @map("market_display_geometry_version_id") @db.Uuid
  manifestSha256                 String   @map("manifest_sha256")
  relationshipsSha256            String   @map("relationships_sha256")
  manifest                       Json
  relationships                  Json
  stagedAt                       DateTime @default(now()) @map("staged_at")

  market                Market                        @relation(fields: [marketId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  marketBoundary        MarketBoundaryVersion         @relation(fields: [marketBoundaryVersionId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  marketDisplayGeometry MarketDisplayGeometryVersion? @relation(fields: [marketDisplayGeometryVersionId], references: [id], onDelete: Restrict, onUpdate: Restrict)

  @@index([marketId, stagedAt(sort: Desc)], map: "geography_dataset_versions_market_staged_idx")
  @@index([marketBoundaryVersionId], map: "geography_dataset_versions_boundary_idx")
  @@index([marketDisplayGeometryVersionId], map: "geography_dataset_versions_display_geometry_idx")
  @@map("geography_dataset_versions")
}

model GeographyActivationSnapshot {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  datasetVersion String    @unique @map("dataset_version")
  marketId       String    @map("market_id") @db.Uuid
  snapshot       Json
  activatedAt    DateTime  @default(now()) @map("activated_at")
  rolledBackAt   DateTime? @map("rolled_back_at")

  market Market @relation(fields: [marketId], references: [id], onDelete: Restrict, onUpdate: Restrict)

  @@index([marketId, activatedAt(sort: Desc)], map: "geography_activation_snapshots_market_activated_idx")
  @@map("geography_activation_snapshots")
}

model ServiceAreaRelationship {
  parentServiceAreaId String                  @map("parent_service_area_id") @db.Uuid
  childServiceAreaId  String                  @map("child_service_area_id") @db.Uuid
  relationType        ServiceAreaRelationType @default(DISPLAY_PARENT) @map("relation_type")
  source              String
  reviewedAt          DateTime?               @map("reviewed_at")
  createdAt           DateTime                @default(now()) @map("created_at")
  updatedAt           DateTime                @default(now()) @updatedAt @map("updated_at")

  parentServiceArea ServiceArea @relation("ServiceAreaRelationshipParent", fields: [parentServiceAreaId], references: [id], onDelete: Cascade, onUpdate: Restrict)
  childServiceArea  ServiceArea @relation("ServiceAreaRelationshipChild", fields: [childServiceAreaId], references: [id], onDelete: Cascade, onUpdate: Restrict)

  @@id([parentServiceAreaId, childServiceAreaId, relationType])
  @@index([childServiceAreaId, relationType, reviewedAt])
  @@index([parentServiceAreaId, relationType, reviewedAt])
  @@map("service_area_relationships")
}

model BuyerDesiredServiceArea {
  buyerProfileId String                        @map("buyer_profile_id")
  serviceAreaId  String                        @map("service_area_id") @db.Uuid
  source         BuyerDesiredServiceAreaSource @default(SELECTED)
  isPrimary      Boolean                       @default(true) @map("is_primary")
  createdAt      DateTime                      @default(now()) @map("created_at")
  updatedAt      DateTime                      @default(now()) @updatedAt @map("updated_at")

  buyerProfile BuyerProfile @relation(fields: [buyerProfileId], references: [id], onDelete: Cascade, onUpdate: Restrict)
  serviceArea  ServiceArea  @relation(fields: [serviceAreaId], references: [id], onDelete: Cascade, onUpdate: Restrict)

  @@id([buyerProfileId, serviceAreaId])
  @@unique([buyerProfileId])
  @@index([serviceAreaId, buyerProfileId])
  @@map("buyer_desired_service_areas")
}

model ServiceAreaMigrationQuarantine {
  id                      String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  buyerProfileId          String       @unique @map("buyer_profile_id")
  buyerProfile            BuyerProfile @relation(fields: [buyerProfileId], references: [id], onDelete: Cascade, onUpdate: Restrict)
  reason                  String
  candidateServiceAreaIds Json         @default("[]") @map("candidate_service_area_ids")
  legacyLocation          Json         @default("{}") @map("legacy_location")
  resolution              Json?
  resolvedAt              DateTime?    @map("resolved_at")
  createdAt               DateTime     @default(now()) @map("created_at")
  updatedAt               DateTime     @default(now()) @updatedAt @map("updated_at")

  @@index([reason, resolvedAt])
  @@map("service_area_migration_quarantine")
}

model BuyerCriteria {
  id             String       @id @default(cuid())
  buyerProfileId String       @unique
  buyerProfile   BuyerProfile @relation(fields: [buyerProfileId], references: [id], onDelete: Cascade)

  propertyCategory PropertyCategory
  propertySubtype  PropertySubtype
  priceMin         Decimal?         @db.Decimal(12, 2)
  priceMax         Decimal?         @db.Decimal(12, 2)
  squareFeetMin    Int?
  squareFeetMax    Int?
  lotSizeMin       Int?
  lotSizeMax       Int?
  bedroomsMin      Int?
  bathroomsMin     Int?
  yearBuiltMin     Int?
  condition        String?
  features         String[]         @default([])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([propertyCategory, propertySubtype])
  @@index([priceMin, priceMax])
}

model BuyerBadge {
  id             String       @id @default(cuid())
  buyerProfileId String
  buyerProfile   BuyerProfile @relation(fields: [buyerProfileId], references: [id], onDelete: Cascade)

  badgeType          BadgeType
  status             BadgeStatus           @default(PENDING)
  issuedAt           DateTime?
  expiresAt          DateTime?
  grantedByUserId    String?               @db.Uuid
  grantedBy          User?                 @relation("BadgeGranter", fields: [grantedByUserId], references: [id], onDelete: SetNull, onUpdate: Restrict)
  grantedAt          DateTime?
  evidenceDocumentId String?
  evidenceDocument   VerificationDocument? @relation("BadgeEvidence", fields: [evidenceDocumentId], references: [id], onDelete: SetNull)
  source             String?
  notes              String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([buyerProfileId, badgeType])
  @@index([buyerProfileId])
  @@index([badgeType, status])
  @@index([expiresAt])
  @@index([grantedByUserId])
  @@index([evidenceDocumentId])
}

model SellerProperty {
  id          String @id @default(cuid())
  ownerUserId String @db.Uuid
  owner       User   @relation("SellerProperties", fields: [ownerUserId], references: [id], onDelete: Cascade, onUpdate: Restrict)

  addressLine1                     String?
  addressLine2                     String?
  city                             String?
  state                            String?
  zip                              String?
  lat                              Decimal?                   @db.Decimal(10, 7)
  lng                              Decimal?                   @db.Decimal(10, 7)
  propertyType                     PropertySubtype
  bedrooms                         Int?
  bathrooms                        Int?
  garageArea                       Int?
  squareFeet                       Int?
  lotSize                          Int?
  condition                        String?
  features                         String[]                   @default([])
  description                      String?
  price                            Decimal?                   @db.Decimal(12, 2)
  ownershipVerificationStatus      PropertyVerificationStatus @default(NOT_SUBMITTED)
  status                           PropertyStatus             @default(DRAFT)
  identityVersion                  Int                        @default(1)
  addressFingerprint               String?
  providerPropertyId               String?
  authorityAttestedAt              DateTime?
  authorityAttestedByUserId        String?                    @db.Uuid
  authorityAttestedBy              User?                      @relation("PropertyAuthorityAttester", fields: [authorityAttestedByUserId], references: [id], onDelete: SetNull, onUpdate: Restrict)
  attestationVersion               String?
  authorityAttestedIdentityVersion Int?
  flaggedForReviewAt               DateTime?

  images                PropertyImage[]
  invites               Invite[]
  documents             VerificationDocument[]
  verificationDecisions PropertyVerificationDecision[]
  uploadSessions        UploadSession[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerUserId])
  @@index([city, state])
  @@index([propertyType])
  @@index([status])
  @@index([authorityAttestedByUserId])
}

model PropertyImage {
  id                      String         @id @default(cuid())
  propertyId              String
  property                SellerProperty @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  storagePath             String         @unique
  propertyIdentityVersion Int
  altText                 String?
  sortOrder               Int            @default(0)
  createdAt               DateTime       @default(now())

  @@index([propertyId])
  @@index([propertyId, propertyIdentityVersion])
}

model VerificationDocument {
  id               String          @id @default(cuid())
  userId           String          @db.Uuid
  user             User            @relation("UserDocuments", fields: [userId], references: [id], onDelete: Cascade, onUpdate: Restrict)
  uploadedByUserId String?         @db.Uuid
  uploadedBy       User?           @relation("DocumentUploader", fields: [uploadedByUserId], references: [id], onDelete: SetNull, onUpdate: Restrict)
  buyerProfileId   String?
  buyerProfile     BuyerProfile?   @relation(fields: [buyerProfileId], references: [id], onDelete: Cascade)
  propertyId       String?
  property         SellerProperty? @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  documentType            DocumentType
  fileSha256              String?
  fileSizeBytes           Int?
  mimeType                String?
  storageBucket           String                 @default("verification-documents")
  storagePath             String
  originalFilename        String?
  uploadedAt              DateTime               @default(now())
  reviewStatus            DocumentStatus         @default(PENDING)
  reviewedByUserId        String?                @db.Uuid
  reviewedBy              User?                  @relation("DocumentReviewer", fields: [reviewedByUserId], references: [id], onDelete: SetNull, onUpdate: Restrict)
  reviewedAt              DateTime?
  reviewNotes             String?
  reviewChecklist         Json?
  rejectionReason         String?
  ownershipEvidenceKind   OwnershipEvidenceKind?
  propertyIdentityVersion Int?

  badgeEvidence            BuyerBadge[]                   @relation("BadgeEvidence")
  governmentIdDecisions    PropertyVerificationDecision[] @relation("GovernmentIdDecision")
  addressEvidenceDecisions PropertyVerificationDecision[] @relation("AddressEvidenceDecision")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([storageBucket, storagePath])
  @@index([userId])
  @@index([uploadedByUserId])
  @@index([buyerProfileId])
  @@index([propertyId])
  @@index([propertyId, ownershipEvidenceKind])
  @@index([propertyId, propertyIdentityVersion, reviewStatus])
  @@index([reviewedByUserId])
  @@index([reviewStatus])
}

model Invite {
  id                      String         @id @default(cuid())
  sellerId                String         @db.Uuid
  seller                  User           @relation("SellerInvites", fields: [sellerId], references: [id], onDelete: Cascade, onUpdate: Restrict)
  buyerProfileId          String
  buyerProfile            BuyerProfile   @relation(fields: [buyerProfileId], references: [id], onDelete: Cascade)
  propertyId              String
  property                SellerProperty @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  propertyIdentityVersion Int

  title                  String
  message                String
  openingTemplateKey     String?
  openingTemplateVersion Int?
  openingNote            String?
  status                 InviteStatus @default(SENT)
  sentAt                 DateTime     @default(now())
  viewedAt               DateTime?
  respondedAt            DateTime?
  expiresAt              DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  emailOutbox  EmailOutbox[]
  conversation Conversation?

  @@index([sellerId])
  @@index([buyerProfileId])
  @@index([propertyId])
  @@index([propertyId, propertyIdentityVersion])
  @@index([status])
}

model Conversation {
  id                  String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  inviteId            String                    @unique
  invite              Invite                    @relation(fields: [inviteId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  status              ConversationStatus        @default(AWAITING_BUYER)
  closedReason        ConversationClosedReason?
  propertySnapshot    Json
  lastMessageAt       DateTime
  moderationUpdatedAt DateTime?

  participants ConversationParticipant[]
  messages     Message[]
  reports      MessageReport[]
  emailOutbox  EmailOutbox[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, lastMessageAt])
  @@index([lastMessageAt, id])
}

model ConversationParticipant {
  conversationId    String                      @db.Uuid
  conversation      Conversation                @relation(fields: [conversationId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  userId            String                      @db.Uuid
  user              User                        @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  role              ConversationParticipantRole
  lastReadMessageId String?                     @db.Uuid
  lastReadMessage   Message?                    @relation("ConversationParticipantLastReadMessage", fields: [conversationId, lastReadMessageId], references: [conversationId, id], onDelete: Restrict, onUpdate: Restrict)
  lastReadAt        DateTime?
  mutedAt           DateTime?
  sentMessages      Message[]                   @relation("MessageSender")
  createdAt         DateTime                    @default(now())

  @@id([conversationId, userId])
  @@unique([conversationId, role])
  @@index([userId, conversationId])
  @@index([conversationId, lastReadMessageId])
}

model Message {
  id               String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conversationId   String                   @db.Uuid
  conversation     Conversation             @relation(fields: [conversationId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  senderUserId     String?                  @db.Uuid
  sender           ConversationParticipant? @relation("MessageSender", fields: [conversationId, senderUserId], references: [conversationId, userId], onDelete: Restrict, onUpdate: Restrict)
  kind             MessageKind
  templateKey      String?
  templateVersion  Int?
  body             String
  clientMessageId  String                   @db.Uuid
  moderationStatus MessageModerationStatus  @default(ALLOWED)
  createdAt        DateTime                 @default(now())

  lastReadBy ConversationParticipant[] @relation("ConversationParticipantLastReadMessage")
  reports    MessageReport[]

  @@unique([conversationId, clientMessageId])
  @@unique([conversationId, id])
  @@index([conversationId, senderUserId])
  @@index([conversationId, createdAt(sort: Desc), id(sort: Desc)])
  @@index([senderUserId, createdAt])
}

model UserBlock {
  blockerUserId String   @db.Uuid
  blocker       User     @relation("UserBlockBlocker", fields: [blockerUserId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  blockedUserId String   @db.Uuid
  blocked       User     @relation("UserBlockBlocked", fields: [blockedUserId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  reason        String?
  createdAt     DateTime @default(now())

  @@id([blockerUserId, blockedUserId])
  @@index([blockedUserId, blockerUserId])
}

model MessageReport {
  id                   String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  reporterUserId       String                @db.Uuid
  reporter             User                  @relation("MessageReportReporter", fields: [reporterUserId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  reportedUserId       String                @db.Uuid
  reportedUser         User                  @relation("MessageReportReportedUser", fields: [reportedUserId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  conversationId       String                @db.Uuid
  conversation         Conversation          @relation(fields: [conversationId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  messageId            String                @db.Uuid
  message              Message               @relation(fields: [conversationId, messageId], references: [conversationId, id], onDelete: Restrict, onUpdate: Restrict)
  category             MessageReportCategory
  details              String?
  evidenceBodySnapshot String
  evidenceContext      Json
  status               MessageReportStatus   @default(OPEN)
  reviewedByUserId     String?               @db.Uuid
  reviewedBy           User?                 @relation("MessageReportReviewer", fields: [reviewedByUserId], references: [id], onDelete: SetNull, onUpdate: Restrict)
  reviewedAt           DateTime?
  resolution           String?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt

  @@unique([reporterUserId, messageId])
  @@index([conversationId, messageId])
  @@index([conversationId, createdAt])
  @@index([messageId])
  @@index([reportedUserId, createdAt])
  @@index([reviewedByUserId])
  @@index([status, createdAt])
}

model Notification {
  id       String    @id @default(cuid())
  userId   String    @db.Uuid
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Restrict)
  type     String
  title    String
  body     String
  readAt   DateTime?
  metadata Json?

  createdAt DateTime @default(now())

  @@index([userId, readAt])
}

model AdminAuditLog {
  id          String   @id @default(cuid())
  actorUserId String?  @db.Uuid
  actor       User?    @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull, onUpdate: Restrict)
  action      String
  targetType  String
  targetId    String
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([actorUserId])
  @@index([targetType, targetId])
  @@index([createdAt])
}

model EmailOutbox {
  id                     String            @id @default(cuid())
  type                   String
  to                     String
  subject                String?
  templateName           String?
  payload                Json
  status                 EmailOutboxStatus @default(PENDING)
  attempts               Int               @default(0)
  lastError              String?
  nextAttemptAt          DateTime?
  sentAt                 DateTime?
  lockedAt               DateTime?
  leaseUntil             DateTime?
  workerId               String?
  providerMessageId      String?
  idempotencyKey         String            @unique
  inviteId               String?
  invite                 Invite?           @relation(fields: [inviteId], references: [id], onDelete: SetNull, onUpdate: Restrict)
  messageConversationId  String?           @db.Uuid
  messageConversation    Conversation?     @relation(fields: [messageConversationId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  messageRecipientUserId String?           @db.Uuid
  messageRecipient       User?             @relation("MessageOutboxRecipient", fields: [messageRecipientUserId], references: [id], onDelete: Restrict, onUpdate: Restrict)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, nextAttemptAt])
  @@index([status, leaseUntil])
  @@index([createdAt])
  @@index([inviteId])
  @@index([messageConversationId])
  @@index([messageRecipientUserId])
  @@index([messageConversationId, messageRecipientUserId, status, nextAttemptAt])
}

model PropertyVerificationDecision {
  id                        String                     @id @default(cuid())
  propertyId                String
  property                  SellerProperty             @relation(fields: [propertyId], references: [id], onDelete: Cascade, onUpdate: Restrict)
  propertyIdentityVersion   Int
  reviewerUserId            String                     @db.Uuid
  reviewer                  User                       @relation("PropertyDecisionReviewer", fields: [reviewerUserId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  governmentIdDocumentId    String
  governmentIdDocument      VerificationDocument       @relation("GovernmentIdDecision", fields: [governmentIdDocumentId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  addressEvidenceDocumentId String
  addressEvidenceDocument   VerificationDocument       @relation("AddressEvidenceDecision", fields: [addressEvidenceDocumentId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  decision                  PropertyVerificationStatus
  checklist                 Json
  notes                     String?
  reviewedAt                DateTime                   @default(now())
  createdAt                 DateTime                   @default(now())

  @@unique([propertyId, propertyIdentityVersion])
  @@index([reviewerUserId])
}

model UploadSession {
  id                      String                 @id @default(cuid())
  ownerUserId             String                 @db.Uuid
  owner                   User                   @relation(fields: [ownerUserId], references: [id], onDelete: Cascade, onUpdate: Restrict)
  purpose                 UploadPurpose
  status                  UploadSessionStatus    @default(PENDING)
  bucket                  String
  storagePath             String                 @unique
  originalFilename        String
  expectedSizeBytes       Int
  expectedMimeType        String
  propertyId              String?
  property                SellerProperty?        @relation(fields: [propertyId], references: [id], onDelete: Cascade, onUpdate: Restrict)
  buyerProfileId          String?
  buyerProfile            BuyerProfile?          @relation(fields: [buyerProfileId], references: [id], onDelete: Cascade, onUpdate: Restrict)
  documentType            DocumentType?
  ownershipEvidenceKind   OwnershipEvidenceKind?
  propertyIdentityVersion Int?
  uploadedAt              DateTime?
  finalizedAt             DateTime?
  expiresAt               DateTime
  rejectionReason         String?
  createdAt               DateTime               @default(now())
  updatedAt               DateTime               @updatedAt

  @@index([ownerUserId, status, expiresAt])
  @@index([propertyId])
  @@index([buyerProfileId])
}

model AuthOperation {
  id             String              @id @default(cuid())
  userId         String              @db.Uuid
  user           User                @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Restrict)
  type           String
  status         AuthOperationStatus @default(PENDING)
  attempts       Int                 @default(0)
  lastError      String?
  nextAttemptAt  DateTime?
  lockedAt       DateTime?
  leaseUntil     DateTime?
  workerId       String?
  completedAt    DateTime?
  idempotencyKey String              @unique
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@index([status, nextAttemptAt, leaseUntil])
  @@index([userId])
}

model RateLimitBucket {
  key         String   @id
  count       Int
  windowStart DateTime
  expiresAt   DateTime
  updatedAt   DateTime @updatedAt

  @@index([expiresAt])
}

model WorkerHeartbeat {
  worker    String   @id
  lastRunAt DateTime
  metadata  Json?
  updatedAt DateTime @updatedAt
}
