generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  BUYER
  SELLER
  ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
}

enum SellerAccessStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum BuyerVisibilityStatus {
  DRAFT
  ACTIVE
  HIDDEN
  SUSPENDED
}

// V1 uses one broad property category with allowlisted property subtypes.
enum PropertyCategory {
  HOME
}

enum PropertySubtype {
  HOME
  CONDO
  TOWNHOUSE
  MANUFACTURED
  LAND
}

enum BadgeType {
  PRE_APPROVED
  EARNEST_MONEY_DEPOSITED
  CASH_BUYER
  NON_CONTINGENT
  VERIFIED_IDENTITY
  VERIFIED_FUNDS
  COMPLETED_TRANSACTION
}

enum BadgeStatus {
  PENDING
  ACTIVE
  EXPIRED
  REJECTED
  REVOKED
}

enum PropertyVerificationStatus {
  NOT_SUBMITTED
  PENDING
  APPROVED
  REJECTED
}

enum DocumentType {
  OWNERSHIP
  PRE_APPROVAL
  VERIFIED_FUNDS
  IDENTITY
  OTHER
}

enum DocumentStatus {
  PENDING
  APPROVED
  REJECTED
}

enum OwnershipEvidenceKind {
  GOVERNMENT_ID
  PROPERTY_ADDRESS_PROOF
}

enum InviteStatus {
  SENT
  VIEWED
  ACCEPTED
  DECLINED
  EXPIRED
  WITHDRAWN
}

enum EmailOutboxStatus {
  PENDING
  SENDING
  SENT
  FAILED
}

model User {
  id            String     @id @db.Uuid
  email         String     @unique
  name          String?
  avatarVariant String?
  roles         UserRole[] @default([])
  status        UserStatus @default(ACTIVE)
  suspendedAt   DateTime?

  buyerProfile        BuyerProfile?
  sellerProperties    SellerProperty[]       @relation("SellerProperties")
  sellerInvites       Invite[]               @relation("SellerInvites")
  sellerAccess        SellerAccess?          @relation("SellerAccessUser")
  sellerAccessReviews SellerAccess[]         @relation("SellerAccessReviewer")
  notifications       Notification[]
  documents           VerificationDocument[] @relation("UserDocuments")
  documentsUploaded   VerificationDocument[] @relation("DocumentUploader")
  badgesGranted       BuyerBadge[]           @relation("BadgeGranter")
  documentsReviewed   VerificationDocument[] @relation("DocumentReviewer")
  auditLogs           AdminAuditLog[]        @relation("AuditActor")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
}

model SellerAccess {
  id               String             @id @default(cuid())
  userId           String             @unique @db.Uuid
  user             User               @relation("SellerAccessUser", fields: [userId], references: [id], onDelete: Cascade)
  status           SellerAccessStatus @default(PENDING)
  reviewedByUserId String?            @db.Uuid
  reviewedBy       User?              @relation("SellerAccessReviewer", fields: [reviewedByUserId], references: [id], onDelete: SetNull)
  reviewedAt       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([reviewedByUserId])
}

model BuyerProfile {
  id     String @id @default(cuid())
  userId String @unique @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  displayName         String
  buyerType           String?
  bio                 String?
  buyingPurpose       String?
  desiredLocationText String?
  desiredCity         String?
  desiredNeighborhood String?
  desiredPostalCode   String?
  desiredState        String?
  desiredLat          Decimal?              @db.Decimal(10, 7)
  desiredLng          Decimal?              @db.Decimal(10, 7)
  budgetMin           Decimal?              @db.Decimal(12, 2)
  budgetMax           Decimal?              @db.Decimal(12, 2)
  downPaymentMin      Decimal?              @db.Decimal(12, 2)
  downPaymentMax      Decimal?              @db.Decimal(12, 2)
  visibilityStatus    BuyerVisibilityStatus @default(DRAFT)
  profileCompleteness Int                   @default(0)
  lastRefreshedAt     DateTime?

  criteria  BuyerCriteria[]
  badges    BuyerBadge[]
  invites   Invite[]
  documents VerificationDocument[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([visibilityStatus])
  @@index([desiredPostalCode])
  @@index([desiredNeighborhood])
  @@index([desiredCity, desiredState])
  @@index([budgetMin, budgetMax])
}

model ServiceArea {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug          String   @unique
  label         String
  type          String
  postalCode    String?  @map("postal_code")
  city          String?
  county        String?
  state         String   @default("CA")
  centerLat     Float    @map("center_lat")
  centerLng     Float    @map("center_lng")
  bboxWest      Float    @map("bbox_west")
  bboxSouth     Float    @map("bbox_south")
  bboxEast      Float    @map("bbox_east")
  bboxNorth     Float    @map("bbox_north")
  geojsonPath   String   @map("geojson_path")
  source        String
  sourceVersion String   @map("source_version")
  active        Boolean  @default(true)
  isPilot       Boolean  @default(true) @map("is_pilot")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at")

  @@index([active, type])
  @@index([postalCode])
  @@map("service_areas")
}

model BuyerCriteria {
  id             String       @id @default(cuid())
  buyerProfileId String
  buyerProfile   BuyerProfile @relation(fields: [buyerProfileId], references: [id], onDelete: Cascade)

  propertyCategory PropertyCategory
  propertySubtype  PropertySubtype
  priceMin         Decimal?         @db.Decimal(12, 2)
  priceMax         Decimal?         @db.Decimal(12, 2)
  squareFeetMin    Int?
  squareFeetMax    Int?
  lotSizeMin       Int?
  lotSizeMax       Int?
  bedroomsMin      Int?
  bathroomsMin     Int?
  yearBuiltMin     Int?
  condition        String?
  features         String[]         @default([])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([buyerProfileId])
  @@index([propertyCategory, propertySubtype])
  @@index([priceMin, priceMax])
}

model BuyerBadge {
  id             String       @id @default(cuid())
  buyerProfileId String
  buyerProfile   BuyerProfile @relation(fields: [buyerProfileId], references: [id], onDelete: Cascade)

  badgeType          BadgeType
  status             BadgeStatus           @default(PENDING)
  issuedAt           DateTime?
  expiresAt          DateTime?
  grantedByUserId    String?               @db.Uuid
  grantedBy          User?                 @relation("BadgeGranter", fields: [grantedByUserId], references: [id], onDelete: SetNull)
  grantedAt          DateTime?
  evidenceDocumentId String?
  evidenceDocument   VerificationDocument? @relation("BadgeEvidence", fields: [evidenceDocumentId], references: [id], onDelete: SetNull)
  source             String?
  notes              String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([buyerProfileId, badgeType])
  @@index([buyerProfileId])
  @@index([badgeType, status])
  @@index([expiresAt])
  @@index([grantedByUserId])
  @@index([evidenceDocumentId])
}

model SellerProperty {
  id          String @id @default(cuid())
  ownerUserId String @db.Uuid
  owner       User   @relation("SellerProperties", fields: [ownerUserId], references: [id], onDelete: Cascade)

  addressLine1                String?
  addressLine2                String?
  city                        String?
  state                       String?
  zip                         String?
  lat                         Decimal?                   @db.Decimal(10, 7)
  lng                         Decimal?                   @db.Decimal(10, 7)
  propertyType                PropertySubtype
  bedrooms                    Int?
  bathrooms                   Int?
  garageArea                  Int?
  squareFeet                  Int?
  lotSize                     Int?
  condition                   String?
  features                    String[]                   @default([])
  description                 String?
  price                       Decimal?                   @db.Decimal(12, 2)
  ownershipVerificationStatus PropertyVerificationStatus @default(NOT_SUBMITTED)
  flaggedForReviewAt          DateTime?

  images    PropertyImage[]
  invites   Invite[]
  documents VerificationDocument[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerUserId])
  @@index([city, state])
  @@index([propertyType])
}

model PropertyImage {
  id          String         @id @default(cuid())
  propertyId  String
  property    SellerProperty @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  storagePath String
  altText     String?
  sortOrder   Int            @default(0)
  createdAt   DateTime       @default(now())

  @@index([propertyId])
}

model VerificationDocument {
  id               String          @id @default(cuid())
  userId           String          @db.Uuid
  user             User            @relation("UserDocuments", fields: [userId], references: [id], onDelete: Cascade)
  uploadedByUserId String?         @db.Uuid
  uploadedBy       User?           @relation("DocumentUploader", fields: [uploadedByUserId], references: [id], onDelete: SetNull)
  buyerProfileId   String?
  buyerProfile     BuyerProfile?   @relation(fields: [buyerProfileId], references: [id], onDelete: Cascade)
  propertyId       String?
  property         SellerProperty? @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  documentType          DocumentType
  fileSha256            String?
  fileSizeBytes         Int?
  mimeType              String?
  storageBucket         String                 @default("verification-documents")
  storagePath           String
  originalFilename      String?
  uploadedAt            DateTime               @default(now())
  reviewStatus          DocumentStatus         @default(PENDING)
  reviewedByUserId      String?                @db.Uuid
  reviewedBy            User?                  @relation("DocumentReviewer", fields: [reviewedByUserId], references: [id], onDelete: SetNull)
  reviewedAt            DateTime?
  reviewNotes           String?
  rejectionReason       String?
  ownershipEvidenceKind OwnershipEvidenceKind?

  badgeEvidence BuyerBadge[] @relation("BadgeEvidence")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([storageBucket, storagePath])
  @@index([userId])
  @@index([uploadedByUserId])
  @@index([buyerProfileId])
  @@index([propertyId])
  @@index([propertyId, ownershipEvidenceKind])
  @@index([reviewedByUserId])
  @@index([reviewStatus])
}

model Invite {
  id             String         @id @default(cuid())
  sellerId       String         @db.Uuid
  seller         User           @relation("SellerInvites", fields: [sellerId], references: [id], onDelete: Cascade)
  buyerProfileId String
  buyerProfile   BuyerProfile   @relation(fields: [buyerProfileId], references: [id], onDelete: Cascade)
  propertyId     String
  property       SellerProperty @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  title       String
  message     String
  status      InviteStatus @default(SENT)
  sentAt      DateTime     @default(now())
  viewedAt    DateTime?
  respondedAt DateTime?
  expiresAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sellerId])
  @@index([buyerProfileId])
  @@index([propertyId])
  @@index([status])
}

model Notification {
  id       String    @id @default(cuid())
  userId   String    @db.Uuid
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type     String
  title    String
  body     String
  readAt   DateTime?
  metadata Json?

  createdAt DateTime @default(now())

  @@index([userId, readAt])
}

model AdminAuditLog {
  id          String   @id @default(cuid())
  actorUserId String?  @db.Uuid
  actor       User?    @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  action      String
  targetType  String
  targetId    String
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([actorUserId])
  @@index([targetType, targetId])
  @@index([createdAt])
}

model EmailOutbox {
  id            String            @id @default(cuid())
  type          String
  to            String
  subject       String?
  templateName  String?
  payload       Json
  status        EmailOutboxStatus @default(PENDING)
  attempts      Int               @default(0)
  lastError     String?
  nextAttemptAt DateTime?
  sentAt        DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, nextAttemptAt])
  @@index([createdAt])
}
